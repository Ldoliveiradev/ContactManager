<configuration>
  <!-- Use only the public NuGet feed for this project so it restores on any machine. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>

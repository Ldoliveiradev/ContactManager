  "item": [
    {
      "name": "Setup - Dynamic User Flow",
      "description": "Run these in order to demonstrate register, login, account fetch, password change, and login again with the new password.",
      "item": [
        {
          "name": "Register unique user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.environment.set('registerUsername', `postman_${suffix}`);",
                  "pm.environment.set('registerEmail', `postman_${suffix}@example.com`);",
                  "pm.environment.set('registerFirstName', 'Postman');",
                  "pm.environment.set('registerLastName', 'Runner');",
                  "pm.environment.set('registerPassword', 'Postman123!');",
                  "pm.environment.set('changedPassword', 'Postman456!');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.isSuccess).to.eql(true);",
                  "pm.environment.set('registeredUserId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registerUsername}}\",\n  \"firstName\": \"{{registerFirstName}}\",\n  \"lastName\": \"{{registerLastName}}\",\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            },
            "url": "{{apiBaseUrl}}/auth/register"
          },
          "response": []
        },
        {
          "name": "Login registered user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.isSuccess).to.eql(true);",
                  "pm.environment.set('token', json.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registerUsername}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            },
            "url": "{{apiBaseUrl}}/auth/login"
          },
          "response": []
        },
        {
          "name": "Get current account",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.isSuccess).to.eql(true);",
                  "pm.environment.set('userId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{apiBaseUrl}}/accounts"
          },
          "response": []
        },
        {
          "name": "Change password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204', function () { pm.response.to.have.status(204); });",
                  "pm.environment.set('registerPassword', pm.environment.get('changedPassword'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"currentPassword\": \"{{registerPassword}}\",\n  \"newPassword\": \"{{changedPassword}}\",\n  \"confirmNewPassword\": \"{{changedPassword}}\"\n}"
            },
            "url": "{{apiBaseUrl}}/auth/change-password"
          },
          "response": []
        },
        {
          "name": "Login registered user with changed password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.isSuccess).to.eql(true);",
                  "pm.environment.set('token', json.data.token);"
                ]
              }
            }

    {
      "name": "Contacts CRUD",
      "description": "Use after logging in. Create stores contactId. Get-all stores the first owned contact id in ownedContactId.",
      "item": [
        {
          "name": "Get my contacts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.isSuccess).to.eql(true);",
                  "if (Array.isArray(json.data) && json.data.length > 0) {",
                  "  pm.environment.set('ownedContactId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{apiBaseUrl}}/contacts?page=1&pageSize=10&sortBy=name&sortDesc=false"
          },
          "response": []
        },
        {
          "name": "Create contact",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.environment.set('contactName', `Postman Contact ${suffix}`);",
                  "pm.environment.set('contactEmail', `postman.contact.${suffix}@example.com`);",
                  "pm.environment.set('contactPhone', '2025550199');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.isSuccess).to.eql(true);",
                  "pm.environment.set('contactId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{contactName}}\",\n  \"email\": \"{{contactEmail}}\",\n  \"phone\": \"{{contactPhone}}\"\n}"
            },
            "url": "{{apiBaseUrl}}/contacts"
          },
          "response": []
        },
        {
          "name": "Get created contact",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{apiBaseUrl}}/contacts/{{contactId}}"
          },
          "response": []
        },
        {
          "name": "Update created contact",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{contactName}} Updated\",\n  \"email\": \"{{contactEmail}}\",\n  \"phone\": \"2025550111\"\n}"
            },
            "url": "{{apiBaseUrl}}/contacts/{{contactId}}"
          },
          "response": []
        },
        {
          "name": "Delete created contact",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "url": "{{apiBaseUrl}}/contacts/{{contactId}}"
          },
          "response": []
        }
      ]
